FROM python:3.11-slim

WORKDIR /app

# Install full pipeline dependencies
COPY requirements-dev.txt .
RUN pip install --no-cache-dir -r requirements-dev.txt

# Copy pipeline code only — data/ is mounted as a volume at runtime
COPY pipeline/ pipeline/

# Default video_urls.txt baked in at build time.
# When data/ is volume-mounted at runtime, the host's version shadows this file.
COPY data/video_urls.txt data/video_urls.txt

ENTRYPOINT ["python", "-m", "pipeline.run"]
CMD ["--full"]
