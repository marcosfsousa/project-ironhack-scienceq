# ── LLM ───────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Embeddings ─────────────────────────────────────────────────
COHERE_API_KEY=your_cohere_api_key_here

# ── Vector Database ────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
# Dev: scienceq-dev | Prod: youtube-qa-bot
PINECONE_INDEX_NAME=scienceq-dev
PINECONE_NAMESPACE_CORPUS=corpus
PINECONE_NAMESPACE_LIVE=live

# ── Reranker ───────────────────────────────────────────────────
# true  → Pinecone fetches 10, Cohere Rerank v3.5 filters to top_k before LLM
# false → standard cosine similarity retrieval (default)
RERANKER_ENABLED=false

# ── LangSmith Tracing ──────────────────────────────────────────
# LANGCHAIN_TRACING_V2 enables LangChain's automatic tracing
LANGCHAIN_TRACING_V2=true
# LANGSMITH_* keys are used directly by the LangSmith SDK (run_evals.py, push_results.py)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=scienceq
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── YouTube Data API ───────────────────────────────────────────
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key_here

# ── Eval Judge (required for run_evals.py) ─────────────────────
OPENAI_API_KEY=your_openai_api_key_here
