# ── LLM ───────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Embeddings ─────────────────────────────────────────────────
COHERE_API_KEY=your_cohere_api_key_here

# ── Vector Database ────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
# Dev: scienceq-dev | Prod: scienceq-prod
PINECONE_INDEX_NAME=scienceq-prod
PINECONE_NAMESPACE_CORPUS=corpus
PINECONE_NAMESPACE_LIVE=live

# ── Retrieval Tuning ───────────────────────────────────────────
# RERANKER_ENABLED=true  → Pinecone fetches RETRIEVER_FETCH_K candidates,
#                          Cohere Rerank v3.5 filters to RETRIEVER_TOP_N.
# RERANKER_ENABLED=false → standard cosine retrieval (RETRIEVER_FETCH_K ignored).
RERANKER_ENABLED=true

# How many candidates Pinecone returns to the reranker (reranker on only)
# Calibrated via Phase 5 retrieval sweep (April 2026).
RETRIEVER_FETCH_K=10

# How many chunks reach the LLM (= Pinecone top_k when reranker off;
#                                 = reranker top_n when reranker on)
# Calibrated via Phase 5 retrieval sweep (April 2026).
RETRIEVER_TOP_N=3

# Minimum cosine similarity score to include a chunk.
# Calibrated via Phase 5 retrieval sweep against Cohere embed-multilingual-v3.0.
# Previous value (0.40) was calibrated for MiniLM and was too aggressive for
# Cohere's embedding space.
SCORE_THRESHOLD=0.25

# ── LangSmith Tracing ──────────────────────────────────────────
# LANGCHAIN_TRACING_V2 enables LangChain's automatic tracing
LANGCHAIN_TRACING_V2=true
# LANGSMITH_* keys are used directly by the LangSmith SDK (run_evals.py, push_results.py)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=scienceq
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── YouTube Data API ───────────────────────────────────────────
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key_here

# ── Eval Judge (required for run_evals.py) ─────────────────────
OPENAI_API_KEY=your_openai_api_key_here
