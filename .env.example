# ── LLM ───────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Embeddings ─────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here

# ── Vector Database ────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=youtube-qa-bot
PINECONE_NAMESPACE_CORPUS=corpus
PINECONE_NAMESPACE_LIVE=live

# ── LangSmith Tracing ──────────────────────────────────────────
# LANGCHAIN_TRACING_V2 enables LangChain's automatic tracing
LANGCHAIN_TRACING_V2=true
# LANGSMITH_* keys are used directly by the LangSmith SDK (run_evals.py, push_results.py)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=youtube-qa-bot
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── YouTube Data API ───────────────────────────────────────────
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key_here

# ── Eval Judge (required for run_evals.py) ─────────────────────
OPENAI_API_KEY=your_openai_api_key_here
